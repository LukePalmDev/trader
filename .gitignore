# macOS
.DS_Store
.AppleDouble
.LSOverride

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
.pytest_cache/
.ruff_cache/
*.egg-info/
dist/
build/
.venv/
venv/
env/

# Dati scraper (snapshot JSON — non committare, il DB tiene lo storico)
data/*.json
data/archive/*.json.gz

# Report runtime
logs/run_report_*.json
!logs/run_report_latest.json

# Log files (generati da cron — non committare)
logs/*.log

# Il DB SQLite unificato viene committato (storico prezzi su GitHub)
# tracker.db  ← NON ignorare questo file
# Vecchi DB separati (obsoleti dopo unificazione)
trader.db
subito.db
ebay.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# SQLite WAL / journal files (transitori, non committare)
*.db-shm
*.db-wal
*.db-journal

# Artefatti di recovery / debug
trader_corrupt.db
trader_dump.sql
trader_recovery.sql

# Test manuali fuori dalla directory tests/
test_anthropic.py

# Playwright
playwright/.local-browsers/

# Claude Code — settings locali (non condividere)
.claude/settings.local.json

# Alert log (stato runtime notifiche, non codice)
alert_log.json

# Database backups and temporary files
backups/
*.pyc
.fuse_hidden*
*.tmp
logs/*_corrupted*
*.corrupted_*
